{
  "name": "typeorm-dynamodb-cdk",
  "version": "1.0.0",
  "description": "AWS CDK utilities to scan TypeORM entities and create DynamoDB tables",
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "npm-run-all clean lint test tsc",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts --fix",
    "prepublishOnly": "npm run build",
    "test": "jest --coverage",
    "tsc": "tsc -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/blueleader07/typeorm-dynamodb-cdk.git"
  },
  "bugs": {
