  },
  "keywords": [
    "typeorm",
    "dynamodb",
    "aws-cdk",
    "cdk",
    "tables",
    "infrastructure"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "aws-cdk-lib": "^2.235.0",
    "constructs": "^10.0.0",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "npm-run-all": "^4.1.5",
    "ts-jest": "29.4.6",
    "ts-node": "^10.9.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.50.1"
  },
  "dependencies": {
    "typeorm": "^0.3.15"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.0.0",
    "constructs": "^10.0.0"
  },
  "engines": {
    "node": ">=18"
